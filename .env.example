# Meta WhatsApp Cloud API
META_TOKEN=your_meta_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_VERIFY_TOKEN=your_verify_token_here

# Google Sheets API
# En Cloud Run: la Service Account asignada al servicio se usa automáticamente (ADC)
# En local: apunta a un JSON de service account descargado (nunca commitear)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# App
APP_ENV=development
